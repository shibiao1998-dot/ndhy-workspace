---
import data from '../../data/data.json';
import CountUp from '../shared/CountUp.astro';

const { org_info } = data;
---

<section class="py-20 md:py-24">
  <div class="container">
    <!-- Organization Name -->
    <h1 class="text-[var(--text-h2)] font-bold text-[var(--color-text-primary)] mb-4">
      {org_info.name}
    </h1>

    <!-- Tagline -->
    <p class="text-[var(--text-h1)] font-bold text-[var(--color-text-primary)] leading-[var(--leading-tight)] mb-10">
      {org_info.tagline}
    </p>

    <!-- Stats Row -->
    <div class="flex flex-wrap gap-8 md:gap-12">
      <div class="flex flex-col">
        <div class="text-[var(--text-h1)] font-bold text-[var(--color-accent-primary)]">
          <CountUp value={org_info.running_days} duration={1200} suffix="天" />
        </div>
        <span class="text-[var(--text-body)] text-[var(--color-text-secondary)] mt-2">已运行</span>
      </div>

      <div class="flex flex-col">
        <div class="text-[var(--text-h1)] font-bold text-[var(--color-accent-primary)]">
          <CountUp value={org_info.total_tasks} duration={1200} />
        </div>
        <span class="text-[var(--text-body)] text-[var(--color-text-secondary)] mt-2">完成任务数</span>
      </div>

      <div class="flex flex-col">
        <div class="text-[var(--text-h1)] font-bold text-[var(--color-accent-primary)]">
          <CountUp value={org_info.ai_experts} duration={1200} suffix="人" />
        </div>
        <span class="text-[var(--text-body)] text-[var(--color-text-secondary)] mt-2">AI 专家</span>
      </div>
    </div>
  </div>
</section>
