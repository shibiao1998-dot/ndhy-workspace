---
import CountUp from '../shared/CountUp.astro';

interface Props {
  emoji: string;
  value: number;
  label: string;
  delay?: number;
}

const { emoji, value, label, delay = 0 } = Astro.props;
---

<div class="card flex-1 min-h-[140px] p-6 flex flex-col items-start gap-3 hover:-translate-y-1">
  <span class="text-[var(--text-h3)]">{emoji}</span>
  <div class="text-[var(--text-h2)] font-bold text-[var(--color-accent-primary)]">
    <CountUp value={value} duration={800} delay={delay} />
  </div>
  <span class="text-[var(--text-small)] text-[var(--color-text-secondary)]">{label}</span>
</div>
