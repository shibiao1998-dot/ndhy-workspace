---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a href={href} class="card p-6 flex flex-col justify-between min-h-[120px] hover:-translate-y-1 group">
  <div>
    <h3 class="text-[var(--text-h4)] font-semibold text-[var(--color-text-primary)] mb-2">
      {title}
    </h3>
    <p class="text-[var(--text-small)] text-[var(--color-text-secondary)]">
      {description}
    </p>
  </div>
  <span class="text-[var(--color-accent-primary)] text-lg self-end group-hover:translate-x-1 transition-transform">
    →
  </span>
</a>
