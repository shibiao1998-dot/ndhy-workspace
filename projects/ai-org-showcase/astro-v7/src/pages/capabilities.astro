---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';

const { skills, skill_categories, models, capability_chain } = data;

// Group skills by category
const skillsByCategory = skill_categories.map((category) => ({
  ...category,
  skills: skills.filter((s) => s.category === category.id),
}));
---

<BaseLayout title="能力矩阵">
  <section class="py-12">
    <div class="container">
      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-[var(--text-h2)] font-bold text-[var(--color-text-primary)] mb-4">
          能力矩阵
        </h1>
        <p class="text-[var(--text-body)] text-[var(--color-text-secondary)]">
          查看 <span class="text-[var(--color-accent-primary)] font-semibold">{skills.length}</span> 个技能与 <span class="text-[var(--color-accent-primary)] font-semibold">{models.total}</span> 个模型的覆盖情况
        </p>
      </div>

      <!-- Skill Categories -->
      <div class="mb-16">
        <h2 class="text-[var(--text-h3)] font-semibold text-[var(--color-text-primary)] mb-6">
          技能分类
        </h2>
        <div class="space-y-3">
          {skillsByCategory.map((category) => (
            <details class="card group">
              <summary class="h-14 flex items-center justify-between px-4 cursor-pointer hover:bg-[var(--color-bg-elevated)] transition-colors">
                <div class="flex items-center gap-3">
                  <span class="text-xl">{category.icon}</span>
                  <span class="text-[var(--text-h4)] font-medium text-[var(--color-text-primary)]">
                    {category.name}
                  </span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="badge badge-accent">{category.count} 个技能</span>
                  <span class="text-[var(--color-text-tertiary)] group-open:rotate-90 transition-transform">
                    ▸
                  </span>
                </div>
              </summary>
              <div class="px-4 pb-4 border-t border-[var(--color-border-default)] pt-4">
                <ul class="space-y-2">
                  {category.skills.map((skill) => (
                    <li class="text-[var(--text-body)] text-[var(--color-text-secondary)] flex items-start gap-2">
                      <span class="text-[var(--color-accent-primary)] mt-1">•</span>
                      {skill.display_name}
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Model Overview -->
      <div class="mb-16">
        <h2 class="text-[var(--text-h3)] font-semibold text-[var(--color-text-primary)] mb-6">
          模型概览
        </h2>

        <!-- Model Types -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
          {models.by_type.map((type) => (
            <div class="card p-4 text-center">
              <span class="text-2xl mb-2 block">{type.icon}</span>
              <span class="text-[var(--text-small)] text-[var(--color-text-primary)] block">
                {type.name}
              </span>
              <span class="text-[var(--color-accent-primary)] font-semibold block mt-1">
                {type.count}
              </span>
            </div>
          ))}
        </div>

        <!-- Highlight Models -->
        <div class="flex flex-wrap gap-2">
          {models.highlights.map((model) => (
            <span
              class="badge"
              style={`background-color: var(--color-accent-secondary-muted); color: var(--color-accent-secondary);`}
            >
              {model.name} · {model.tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Capability Chain -->
      <div>
        <h2 class="text-[var(--text-h3)] font-semibold text-[var(--color-text-primary)] mb-6">
          全链路覆盖
        </h2>
        <div class="flex flex-wrap items-center justify-between gap-4">
          {capability_chain.map((stage, index) => (
            <>
              <div class="flex flex-col items-center">
                <div
                  class="w-10 h-10 rounded-full border-2 border-[var(--color-accent-primary)] flex items-center justify-center text-[var(--color-accent-primary)] font-semibold"
                >
                  {index + 1}
                </div>
                <span class="text-[var(--text-small)] text-[var(--color-text-primary)] mt-2">
                  {stage.stage}
                </span>
                <span class="text-[var(--text-caption)] text-[var(--color-text-tertiary)]">
                  {stage.skills} 技能 · {stage.experts} 专家
                </span>
              </div>
              {index < capability_chain.length - 1 && (
                <div class="flex-1 h-[1px] bg-[var(--color-border-default)] min-w-[20px]"></div>
              )}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
