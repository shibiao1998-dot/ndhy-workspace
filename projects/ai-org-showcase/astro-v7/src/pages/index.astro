---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import Hero from '../components/landing/Hero.astro';
import StatsCards from '../components/landing/StatsCards.astro';
import QuickNav from '../components/landing/QuickNav.astro';

const { org_info } = data;
---

<BaseLayout title="首页">
  <!-- Hero Section -->
  <Hero />

  <!-- Stats Cards Section -->
  <section class="py-12">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <StatsCards
          emoji="👥"
          value={org_info.ai_experts}
          label="AI 专家"
          delay={0}
        />
        <StatsCards
          emoji="⚡"
          value={org_info.total_skills}
          label="专业技能"
          delay={150}
        />
        <StatsCards
          emoji="🤖"
          value={org_info.total_models}
          label="接入模型"
          delay={300}
        />
      </div>
    </div>
  </section>

  <!-- Quick Navigation Section -->
  <section class="py-12">
    <div class="container">
      <h2 class="text-[var(--text-h3)] font-semibold text-[var(--color-text-primary)] mb-8">
        探索团队
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <QuickNav
          title="认识团队"
          description="了解 30 位 AI 专家的分工与职责"
          href="/team/"
        />
        <QuickNav
          title="能力矩阵"
          description="查看 51 个技能与 142 个模型的覆盖"
          href="/capabilities/"
        />
        <QuickNav
          title="实时活动"
          description="过去 24 小时发生了什么"
          href="/activity/"
        />
      </div>
    </div>
  </section>
</BaseLayout>
