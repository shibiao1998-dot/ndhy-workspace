---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center max-w-[480px] px-4">
      <!-- 404 Number -->
      <div class="text-[6rem] md:text-[8rem] font-bold text-[var(--color-accent-primary)] opacity-30 mb-4">
        404
      </div>

      <!-- Title -->
      <h1 class="text-[var(--text-h2)] font-bold text-[var(--color-text-primary)] mb-4">
        页面走丢了
      </h1>

      <!-- Description -->
      <p class="text-[var(--text-body)] text-[var(--color-text-secondary)] mb-8">
        抱歉，您访问的页面不存在或已被移除。
      </p>

      <!-- Back to Home Button -->
      <a href="/" class="btn-primary mb-8">
        返回首页
      </a>

      <!-- Quick Links -->
      <div class="flex flex-wrap justify-center gap-4 text-[var(--text-small)]">
        <a href="/team/" class="text-[var(--color-accent-primary)] hover:underline">
          认识团队
        </a>
        <span class="text-[var(--color-text-tertiary)]">·</span>
        <a href="/capabilities/" class="text-[var(--color-accent-primary)] hover:underline">
          能力矩阵
        </a>
        <span class="text-[var(--color-text-tertiary)]">·</span>
        <a href="/activity/" class="text-[var(--color-accent-primary)] hover:underline">
          活动流
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
