---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';

const { experts, org_layers } = data;

function getLayerEmoji(layerName: string): string {
  const emojis: Record<string, string> = {
    '需求洞察层': '🎯',
    '战略与定义层': '🧭',
    '流程与角色层': '🔩',
    '文档与调研层': '📖',
    '设计层': '🎨',
    '架构与数据层': '🏛️',
    '开发层': '💻',
    '质量层': '🧪',
    '交付层': '🚀',
    '增长与迭代层': '📈',
    '组织治理层': '🏗️',
    '教育专业层': '🎓',
  };
  return emojis[layerName] || '⚙️';
}
---

<BaseLayout title="团队">
  <section class="py-12">
    <div class="container">
      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-[var(--text-h2)] font-bold text-[var(--color-text-primary)] mb-4">
          组织全景
        </h1>
        <p class="text-[var(--text-body)] text-[var(--color-text-secondary)]">
          探索 <span class="text-[var(--color-accent-primary)] font-semibold">{experts.length}</span> 位 AI 专家的分工与职责
        </p>
      </div>

      <!-- Organization Layers -->
      <div class="space-y-3 mb-12">
        {org_layers.map((layer) => (
          <div
            id={`layer-${layer.order}`}
            class="h-12 rounded-md bg-[var(--color-bg-surface)] flex items-center px-4 hover:bg-[var(--color-bg-elevated)] hover:border-l-[3px] hover:border-[var(--color-accent-primary)] transition-all cursor-pointer"
          >
            <span class="text-[var(--text-small)] font-medium text-[var(--color-text-primary)]">
              {layer.name}
            </span>
            <span class="ml-auto text-[var(--text-tertiary)] text-[var(--text-caption)]">
              {layer.expert_count} 人
            </span>
          </div>
        ))}
      </div>

      <!-- Expert Cards by Layer -->
      {org_layers.map((layer) => (
        <div class="mb-12">
          <h2 class="text-[var(--text-h3)] font-semibold text-[var(--color-text-primary)] mb-6 flex items-center gap-2">
            <span>{getLayerEmoji(layer.name)}</span>
            {layer.name}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {experts
              .filter((expert) => expert.layer === layer.name)
              .map((expert) => (
                <div class="card p-5 min-h-[100px] hover:-translate-y-1 transition-all">
                  <div class="text-2xl mb-3">{expert.emoji}</div>
                  <h3 class="text-[var(--text-h4)] font-medium text-[var(--color-text-primary)] mb-2">
                    {expert.name}
                  </h3>
                  <span class="badge badge-accent text-[var(--text-caption)]">
                    {layer.name}
                  </span>
                  <p class="text-[var(--text-small)] text-[var(--color-text-secondary)] mt-3 line-clamp-2">
                    {expert.capability}
                  </p>
                </div>
              ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>