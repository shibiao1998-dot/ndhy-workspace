---
/**
 * BreathingPoint — Emotional reset between major sections.
 * Minimal design: space, text, and restraint.
 */
---

<section class="section breathing" aria-label="情绪留白">
  <div class="section-content breathing__content">
    <div class="breathing__text anim-blur-reveal">
      <p class="breathing__line">以上不是个例。</p>
      <p class="breathing__line">这是每一天的日常。</p>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('.breathing .anim-blur-reveal')
    .forEach((el) => observer.observe(el));
</script>

<style>
  .breathing {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
  }

  .breathing__content {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breathing__text {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .breathing__line {
    font-size: var(--fs-h2);
    font-weight: var(--fw-normal);
    color: var(--color-text-muted);
    line-height: var(--lh-heading);
    font-family: var(--font-sans);
  }

  /* === Mobile === */
  @media (max-width: 767px) {
    .breathing {
      min-height: 50vh;
    }
  }

  /* === Desktop === */
  @media (min-width: 1024px) {
    .breathing__line {
      font-size: var(--fs-h1);
    }
  }
</style>
