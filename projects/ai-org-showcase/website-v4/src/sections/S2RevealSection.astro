---
/**
 * S2RevealSection — Organization topology graph showing 31 AI nodes.
 * Desktop: React Island for interactive topology (placeholder).
 * Mobile: Vertical layered HTML grid (L0→L1→L2→L3).
 */
import { teamMembers, domains, getMembersByLevel, getMembersByDomain } from '../data/team-members';
import TopologyGraph from '../components/TopologyGraph.tsx';

const l0 = getMembersByLevel('L0');
const l1 = getMembersByLevel('L1');
const l2 = getMembersByLevel('L2');
const l3 = getMembersByLevel('L3');

// Group L3 by domain
const l3ByDomain = domains
  .map(domain => ({
    domain,
    members: getMembersByDomain(domain).filter(m => m.level === 'L3'),
  }))
  .filter(g => g.members.length > 0);
---

<section class="section reveal" aria-label="组织拓扑">
  <div class="section-content">

    <h2 class="reveal__heading anim-fade-up">组织拓扑</h2>

    <!-- Desktop: React Island for interactive topology graph -->
    <div class="topology-desktop" aria-label="交互式组织拓扑图">
      <TopologyGraph client:visible members={teamMembers} />
    </div>

    <!-- Mobile: Vertical layered grid -->
    <div class="topology-mobile" role="list" aria-label="组织层级结构">

      <!-- L0 — Human Layer -->
      <div class="topo-layer" role="listitem">
        <span class="topo-layer__label topo-layer__label--l0">L0 · 人类层</span>
        <div class="topo-layer__nodes topo-layer__nodes--center">
          {l0.map((member) => (
            <div
              class="topo-node topo-node--l0"
              data-topo-node
              data-level="L0"
              role="listitem"
              aria-label={`${member.name} — ${member.description}`}
            >
              <span class="topo-node__emoji" aria-hidden="true">{member.emoji}</span>
              <span class="topo-node__name">{member.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Connection line -->
      <div class="topo-connector" aria-hidden="true"></div>

      <!-- L1 — Organization Core -->
      <div class="topo-layer" role="listitem">
        <span class="topo-layer__label topo-layer__label--l1">L1 · 组织核心</span>
        <div class="topo-layer__nodes topo-layer__nodes--center">
          {l1.map((member) => (
            <div
              class="topo-node topo-node--l1"
              data-topo-node
              data-level="L1"
              role="listitem"
              aria-label={`${member.name} — ${member.description}`}
            >
              <span class="topo-node__emoji" aria-hidden="true">{member.emoji}</span>
              <span class="topo-node__name">{member.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Connection line -->
      <div class="topo-connector" aria-hidden="true"></div>

      <!-- L2 — Project Dispatch -->
      <div class="topo-layer" role="listitem">
        <span class="topo-layer__label topo-layer__label--l2">L2 · 项目调度</span>
        <div class="topo-layer__nodes topo-layer__nodes--center">
          {l2.map((member) => (
            <div
              class="topo-node topo-node--l2"
              data-topo-node
              data-level="L2"
              role="listitem"
              aria-label={`${member.name} — ${member.description}`}
            >
              <span class="topo-node__emoji" aria-hidden="true">{member.emoji}</span>
              <span class="topo-node__name">{member.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Connection line -->
      <div class="topo-connector" aria-hidden="true"></div>

      <!-- L3 — Experts by Domain -->
      <div class="topo-layer topo-layer--l3" role="listitem">
        <span class="topo-layer__label topo-layer__label--l3">L3 · 专家层</span>
        <div class="topo-layer__domains">
          {l3ByDomain.map((group) => (
            <div class="topo-domain-group">
              <span class="topo-domain-group__label">{group.domain}</span>
              <div class="topo-domain-group__grid">
                {group.members.map((member) => (
                  <div
                    class="topo-node topo-node--l3"
                    data-topo-node
                    data-level="L3"
                    role="listitem"
                    aria-label={`${member.name} — ${member.description}`}
                  >
                    <span class="topo-node__emoji" aria-hidden="true">{member.emoji}</span>
                    <span class="topo-node__name">{member.name}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom text -->
    <div class="reveal__bottom">
      <p class="reveal__headline anim-scale-spring">
        一个人类 · 31 个 AI 专家 · 一个完整的产品组织
      </p>
      <p class="reveal__subtext anim-scale-spring" style={`transition-delay: var(--dur-fast);`}>
        不是工具，不是框架，不是 Prompt 模板<br />
        是一支有灵魂、有纪律、有记忆、会进化的 AI 组织
      </p>
    </div>

  </div>
</section>

<script>
  // Animate topology nodes on scroll into view
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const nodes = entry.target.querySelectorAll('[data-topo-node]');
          nodes.forEach((node, i) => {
            const el = node as HTMLElement;
            el.style.transitionDelay = `${i * 60}ms`;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  const mobileGrid = document.querySelector('.topology-mobile');
  if (mobileGrid) {
    observer.observe(mobileGrid);
  }

  // Animate .anim-fade-up and .anim-scale-spring elements
  const animObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          animObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('.reveal .anim-fade-up, .reveal .anim-scale-spring')
    .forEach((el) => animObserver.observe(el));
</script>

<style>
  /* === Section === */
  .reveal {
    background-color: var(--color-bg);
  }

  .reveal__heading {
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    text-align: center;
    margin-bottom: var(--space-10);
    line-height: var(--lh-heading);
  }

  /* === Desktop topology placeholder === */
  .topology-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .topology-desktop {
      display: block;
      margin-bottom: var(--space-10);
    }

    .topology-mobile {
      display: none;
    }
  }

  .topology-desktop__placeholder {
    min-height: var(--space-24);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: var(--color-bg-surface);
  }

  .topology-desktop__hint {
    font-size: var(--fs-small);
    color: var(--color-text-dim);
    letter-spacing: var(--ls-wide);
  }

  /* === Mobile topology grid === */
  .topology-mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .topology-mobile {
      display: none;
    }
  }

  /* === Layer === */
  .topo-layer {
    width: 100%;
  }

  .topo-layer__label {
    display: block;
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
    letter-spacing: var(--ls-wide);
    margin-bottom: var(--space-2);
    text-align: center;
    font-weight: var(--fw-medium);
  }

  .topo-layer__label--l0 { color: var(--color-boss); }
  .topo-layer__label--l1 { color: var(--color-accent); }
  .topo-layer__label--l2 { color: var(--color-info); }
  .topo-layer__label--l3 { color: var(--color-text-muted); }

  .topo-layer__nodes--center {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* === Connection lines === */
  .topo-connector {
    width: 1px;
    height: var(--space-6);
    background: var(--color-border-subtle);
  }

  /* === L3 domain groups === */
  .topo-layer__domains {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .topo-domain-group__label {
    display: block;
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
    margin-bottom: var(--space-1);
    padding-left: var(--space-1);
  }

  .topo-domain-group__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  /* === Node === */
  .topo-node {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: var(--space-12);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    opacity: 0.3;
    transform: translateY(var(--space-2));
    transition:
      opacity var(--dur-normal) var(--ease-out),
      transform var(--dur-normal) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  .topo-node__emoji {
    font-size: var(--fs-body);
    flex-shrink: 0;
  }

  .topo-node__name {
    font-size: var(--fs-small);
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* === Node level accents === */
  .topo-node--l0 {
    border-color: var(--color-boss);
    background: var(--color-level-l0-bg);
  }
  .topo-node--l0 .topo-node__name { color: var(--color-boss); font-weight: var(--fw-semibold); }

  .topo-node--l1 {
    border-color: var(--color-accent);
    background: var(--color-level-l1-bg);
  }
  .topo-node--l1 .topo-node__name { color: var(--color-accent); font-weight: var(--fw-medium); }

  .topo-node--l2 {
    border-color: var(--color-info);
    background: var(--color-level-l2-bg);
  }
  .topo-node--l2 .topo-node__name { color: var(--color-info); }

  .topo-node--l3 {
    background: var(--color-level-l3-bg);
  }

  /* === Bottom text === */
  .reveal__bottom {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-8);
  }

  .reveal__headline {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    line-height: var(--lh-heading);
  }

  .reveal__subtext {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    line-height: var(--lh-body);
  }

  /* === Desktop refinements === */
  @media (min-width: 1024px) {
    .reveal__headline {
      font-size: var(--fs-display);
    }

    .reveal__subtext {
      font-size: var(--fs-h2);
    }
  }
</style>
