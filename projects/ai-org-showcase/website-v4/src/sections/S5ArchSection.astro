---
/**
 * S5ArchSection — Deep Architecture cross-section diagrams.
 * 3 independent panels: Power Structure, Memory System, Continuous Evolution.
 * One-screen-one-concept. Scroll-triggered animations with stagger.
 */
---

<section class="section arch" aria-label="深层架构">
  <div class="section-content">

    <!-- Intro -->
    <div class="arch__intro">
      <h2 class="arch__intro-line anim-fade-up">切开这个 AI 组织</h2>
      <p class="arch__intro-line anim-fade-up" data-delay="120">看看它为什么能运转</p>
    </div>

    <!-- Panel A: 权力结构 -->
    <article class="arch__panel anim-clip-expand" aria-label="权力结构">
      <div class="arch__panel-inner">
        <h3 class="arch__panel-subtitle anim-blur-reveal">权力结构</h3>
        <p class="arch__panel-hint anim-blur-reveal" data-delay="60">不是所有 AI 都平等</p>

        <div class="arch__rows" role="list" aria-label="权力层级">
          <div class="arch__row anim-fade-up" data-delay="0" role="listitem">
            <span class="arch__row-level arch__row-level--l0">L0</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">老板</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━━━━━━━━━━</span>
            <span class="arch__row-desc">做不做</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="60" role="listitem">
            <span class="arch__row-level arch__row-level--l1">L1</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">Leader</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━━━━━━━━</span>
            <span class="arch__row-desc">做成什么样</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="120" role="listitem">
            <span class="arch__row-level arch__row-level--l2">L2</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">项目管理专家</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━━━</span>
            <span class="arch__row-desc">怎么拆、谁先做</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="180" role="listitem">
            <span class="arch__row-level arch__row-level--l3">L3</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">30 位领域专家</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━━</span>
            <span class="arch__row-desc">自己领域内怎么做最好</span>
          </div>
        </div>

        <div class="arch__panel-bottom anim-fade-up" data-delay="300">
          <p>不是 AI 替代人类决策</p>
          <p class="arch__panel-bottom-bright">是人类授权 AI 在专业范围内自主决策</p>
        </div>
      </div>
    </article>

    <!-- Panel B: 记忆体系 -->
    <article class="arch__panel anim-clip-expand" aria-label="记忆体系">
      <div class="arch__panel-inner">
        <h3 class="arch__panel-subtitle anim-blur-reveal">记忆体系</h3>
        <p class="arch__panel-hint anim-blur-reveal" data-delay="60">为什么越用越强</p>

        <div class="arch__rows" role="list" aria-label="记忆层级">
          <div class="arch__row anim-fade-up" data-delay="0" role="listitem">
            <span class="arch__row-icon" aria-hidden="true">🔥</span>
            <span class="arch__row-tag arch__row-tag--hot">HOT</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">价值观、经验法则</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━</span>
            <span class="arch__row-desc">永远记住</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="60" role="listitem">
            <span class="arch__row-icon" aria-hidden="true">🟡</span>
            <span class="arch__row-tag arch__row-tag--warm">WARM</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">今天发生了什么</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━━</span>
            <span class="arch__row-desc">每日归档</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="120" role="listitem">
            <span class="arch__row-icon" aria-hidden="true">📁</span>
            <span class="arch__row-tag arch__row-tag--proj">PROJ</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">这个项目的上下文</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━</span>
            <span class="arch__row-desc">项目生命周期</span>
          </div>
          <div class="arch__row anim-fade-up" data-delay="180" role="listitem">
            <span class="arch__row-icon" aria-hidden="true">🆘</span>
            <span class="arch__row-tag arch__row-tag--sos">应急</span>
            <span class="arch__row-separator" aria-hidden="true">━━</span>
            <span class="arch__row-name">上下文溢出备份</span>
            <span class="arch__row-dash" aria-hidden="true">━━━━━━━</span>
            <span class="arch__row-desc">按需调用</span>
          </div>
        </div>

        <div class="arch__panel-bottom anim-fade-up" data-delay="300">
          <p class="arch__panel-bottom-bright">每一次纠正 → 最高优先级信号 → 立即记录 → 永不重犯</p>
        </div>
      </div>
    </article>

    <!-- Panel C: 持续进化 -->
    <article class="arch__panel anim-clip-expand" aria-label="持续进化">
      <div class="arch__panel-inner">
        <h3 class="arch__panel-subtitle anim-blur-reveal">持续进化</h3>
        <p class="arch__panel-hint anim-blur-reveal" data-delay="60">同一个错误不犯两次</p>

        <div class="arch__cards" role="list" aria-label="进化机制">
          <div class="arch__card anim-fade-up" data-delay="0" role="listitem">
            <h4 class="arch__card-title">纠正即学习</h4>
            <p class="arch__card-desc">人类纠正一次 → 立即写入记忆 → 全组织生效</p>
          </div>
          <div class="arch__card anim-fade-up" data-delay="60" role="listitem">
            <h4 class="arch__card-title">模式识别</h4>
            <p class="arch__card-desc">同一模式出现 3 次 → 自动提炼为规则 → 沉淀为组织知识</p>
          </div>
          <div class="arch__card anim-fade-up" data-delay="120" role="listitem">
            <h4 class="arch__card-title">经验继承</h4>
            <p class="arch__card-desc">每个项目的决策和教训 → 下一个项目自动继承<br />不从零开始</p>
          </div>
        </div>
      </div>
    </article>

  </div>
</section>

<style>
  /* === Section === */
  .arch {
    background-color: var(--color-bg);
  }

  /* === Intro === */
  .arch__intro {
    text-align: center;
    margin-bottom: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .arch__intro-line {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    line-height: var(--lh-heading);
  }

  /* === Panel shared === */
  .arch__panel {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-16);
  }

  .arch__panel:last-of-type {
    margin-bottom: var(--space-0);
  }

  .arch__panel-inner {
    width: 100%;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .arch__panel-subtitle {
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    line-height: var(--lh-heading);
  }

  .arch__panel-hint {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    line-height: var(--lh-body);
    margin-top: calc(-1 * var(--space-3));
  }

  /* === Rows (Power + Memory panels) === */
  .arch__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .arch__row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-bg-elevated);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    line-height: var(--lh-small);
    color: var(--color-text);
    overflow-x: auto;
    white-space: nowrap;
  }

  .arch__row-level {
    font-weight: var(--fw-bold);
    flex-shrink: 0;
    min-width: var(--space-6);
  }

  .arch__row-level--l0 { color: var(--color-boss); }
  .arch__row-level--l1 { color: var(--color-accent); }
  .arch__row-level--l2 { color: var(--color-info); }
  .arch__row-level--l3 { color: var(--color-text-muted); }

  .arch__row-separator {
    color: var(--color-text-dim);
    flex-shrink: 0;
  }

  .arch__row-name {
    font-weight: var(--fw-medium);
    color: var(--color-text-bright);
    flex-shrink: 0;
  }

  .arch__row-dash {
    color: var(--color-text-disabled);
    flex-shrink: 1;
    overflow: hidden;
  }

  .arch__row-desc {
    color: var(--color-text-muted);
    flex-shrink: 0;
    margin-left: auto;
  }

  /* === Memory panel icons & tags === */
  .arch__row-icon {
    flex-shrink: 0;
    font-size: var(--fs-body);
  }

  .arch__row-tag {
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wide);
    flex-shrink: 0;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .arch__row-tag--hot {
    color: var(--color-error);
    background: var(--color-error-bg);
  }

  .arch__row-tag--warm {
    color: var(--color-warning);
    background: var(--color-warning-bg);
  }

  .arch__row-tag--proj {
    color: var(--color-info);
    background: var(--color-info-bg);
  }

  .arch__row-tag--sos {
    color: var(--color-success);
    background: var(--color-success-bg);
  }

  /* === Cards (Evolution panel) === */
  .arch__cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .arch__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .arch__card-title {
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    line-height: var(--lh-heading);
  }

  .arch__card-desc {
    font-size: var(--fs-body);
    color: var(--color-text);
    line-height: var(--lh-body);
  }

  /* === Panel bottom text === */
  .arch__panel-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    line-height: var(--lh-body);
  }

  .arch__panel-bottom-bright {
    color: var(--color-text-bright);
    font-weight: var(--fw-medium);
  }

  /* === Mobile adjustments === */
  @media (max-width: 767px) {
    .arch__intro-line {
      font-size: var(--fs-h2);
    }

    .arch__panel {
      min-height: 70vh;
    }

    .arch__panel-inner {
      padding: var(--space-4);
    }

    .arch__row {
      font-size: var(--fs-xs);
      padding: var(--space-2) var(--space-3);
      gap: var(--space-1);
    }

    /* Hide long dashes on mobile to save space */
    .arch__row-dash {
      display: none;
    }

    .arch__card {
      padding: var(--space-4);
    }
  }

  /* === Desktop refinements === */
  @media (min-width: 1024px) {
    .arch__intro-line {
      font-size: var(--fs-display);
    }

    .arch__panel-inner {
      padding: var(--space-8);
      gap: var(--space-8);
    }

    .arch__row {
      font-size: var(--fs-body);
      padding: var(--space-4) var(--space-6);
    }

    .arch__card {
      padding: var(--space-6) var(--space-8);
    }

    .arch__cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
  }
</style>
