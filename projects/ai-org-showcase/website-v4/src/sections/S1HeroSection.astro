---
/**
 * S1HeroSection — Cinematic opening with typewriter effect.
 * Full viewport, dark background, sequential text reveals.
 */
---

<section class="hero" aria-label="开场叙事">
  <h1 class="sr-only">一个人启动了一个项目，6 天后拥有了 31 人的产品团队</h1>

  <div class="hero__content">
    <!-- Line 1: Date -->
    <p class="hero__line hero__date" aria-label="日期">
      2026 年 3 月 10 日
    </p>

    <!-- Line 2: Typewriter -->
    <p class="hero__line hero__typewriter" aria-label="一个人启动了一个项目">
      <span class="typewriter__text">一个人启动了一个项目</span>
    </p>

    <!-- Line 3: Two-line reveal -->
    <div class="hero__line hero__reveal-group" aria-label="6 天后的结果">
      <p class="hero__reveal-line-1">6 天后，</p>
      <p class="hero__reveal-line-2">他拥有了一个 31 人的产品团队</p>
    </div>

    <!-- Line 4: Punch line -->
    <p class="hero__line hero__punch" aria-label="他没有招过一个人">
      他没有招过一个人    </p>
  </div>

  <!-- Category hint -->
  <span class="hero__category" aria-hidden="true">AI Organization</span>

  <!-- Scroll arrow -->
  <div class="hero__scroll-arrow" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

<style>
  /* === Hero Section === */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
    padding-left: var(--section-px);
    padding-right: var(--section-px);
    overflow: hidden;
  }

  /* Visually hidden heading for a11y */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* === Content container === */
  .hero__content {
    max-width: var(--max-w-content);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
    font-family: var(--font-sans);
  }

  /* === Shared line styles === */
  .hero__line {
    font-size: var(--fs-h2);
    line-height: var(--lh-heading);
    color: var(--color-text);
  }

  /* === Line 1: Date — fade in === */
  .hero__date {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    letter-spacing: var(--ls-wide);
    opacity: 0;
    animation: heroFadeIn var(--dur-slow) var(--ease-out) forwards;
    animation-delay: 300ms;
  }

  /* === Line 2: Typewriter === */
  .hero__typewriter {
    display: flex;
    justify-content: center;
    font-size: var(--fs-h1);
    font-weight: var(--fw-medium);
  }

  .typewriter__text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid var(--color-text-bright);
    width: 0;
    animation:
      typewriter 1.6s steps(12, end) forwards,
      blink 530ms step-end infinite;
    animation-delay: 1s, 1s;
  }

  /* === Line 3: Reveal group === */
  .hero__reveal-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .hero__reveal-line-1,
  .hero__reveal-line-2 {
    font-size: var(--fs-h2);
    opacity: 0;
    animation: heroFadeIn var(--dur-slow) var(--ease-out) forwards;
  }

  .hero__reveal-line-1 {
    animation-delay: 3s;
  }

  .hero__reveal-line-2 {
    animation-delay: 3.5s;
  }

  /* === Line 4: Punch line === */
  .hero__punch {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    color: var(--color-text-bright);
    opacity: 0;
    animation: heroFadeIn var(--dur-slow) var(--ease-out) forwards;
    animation-delay: 4.5s;
  }

  /* === Category hint === */
  .hero__category {
    position: absolute;
    bottom: var(--space-16);
    opacity: 0.15;
    font-size: var(--fs-xs);
    font-family: var(--font-sans);
    letter-spacing: var(--ls-wide);
    color: var(--color-text);
    text-transform: uppercase;
  }

  /* === Scroll arrow === */
  .hero__scroll-arrow {
    position: absolute;
    bottom: var(--space-8);
    color: var(--color-text-dim);
    animation: breathe 2s var(--ease-in-out) infinite;
  }

  .hero__scroll-arrow svg {
    display: block;
  }

  /* === Keyframes === */
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(var(--space-2));
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes typewriter {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }

  /* === Mobile adjustments === */
  @media (max-width: 767px) {
    .hero__line {
      font-size: var(--fs-body);
    }

    .hero__typewriter {
      font-size: var(--fs-h2);
    }

    .typewriter__text {
      /* Smaller text = shorter animation on mobile */
      animation:
        typewriter 1.4s steps(12, end) forwards,
        blink 530ms step-end infinite;
      animation-delay: 1s, 1s;
    }

    .hero__punch {
      font-size: var(--fs-h2);
    }

    .hero__category {
      bottom: var(--space-12);
    }
  }

  /* === Desktop adjustments === */
  @media (min-width: 1024px) {
    .hero__content {
      gap: var(--space-8);
    }

    .hero__line {
      font-size: var(--fs-h1);
    }

    .hero__typewriter {
      font-size: var(--fs-display);
    }

    .hero__punch {
      font-size: var(--fs-display);
    }
  }
</style>
