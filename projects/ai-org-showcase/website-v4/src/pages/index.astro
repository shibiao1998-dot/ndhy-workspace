---
import BaseLayout from '../layouts/BaseLayout.astro';
import S1HeroSection from '../sections/S1HeroSection.astro';
import S2RevealSection from '../sections/S2RevealSection.astro';
import S3TimelineSection from '../sections/S3TimelineSection.astro';
import BreathingPoint from '../sections/BreathingPoint.astro';
import S4ContrastSection from '../sections/S4ContrastSection.astro';
import S5ArchSection from '../sections/S5ArchSection.astro';
import S6VisionSection from '../sections/S6VisionSection.astro';
import S7CtaSection from '../sections/S7CtaSection.astro';
---

<BaseLayout>
  <S1HeroSection />
  <S2RevealSection />
  <S3TimelineSection />
  <BreathingPoint />
  <S4ContrastSection />
  <S5ArchSection />
  <S6VisionSection />
  <S7CtaSection />
</BaseLayout>

<script>
  import { initSmoothScroll, cleanupSmoothScroll } from '../animations/scroll-setup';
  import { initScrollAnimations } from '../animations/section-triggers';

  // Initialize animations after DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    initSmoothScroll();
    const cleanupAnimations = initScrollAnimations();

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      cleanupAnimations();
      cleanupSmoothScroll();
    });
  });
</script>
