---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'NDHY AI Agent Team — 一个人类，31 个 AI 专家，一个完整的产品组织',
  description = '不是工具，不是框架——是一支有灵魂、有纪律、有记忆、会进化的 AI 组织，覆盖产品全链路的每一个环节',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="no-js">
  <script is:inline>document.documentElement.classList.remove('no-js')</script>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <canvas id="particles-canvas" aria-hidden="true"></canvas>
    <a href="#main-content" class="skip-link">跳转到主要内容</a>
    <main id="main-content">
      <slot />
    </main>
    <script is:inline>
    /* === Particle System — High-Tech Background === */
    (function initParticles() {
      var canvas = document.getElementById('particles-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var W, H;
      var particles = [];
      var mouse = { x: -9999, y: -9999 };
      var COLORS = [
        [0, 200, 255],
        [124, 58, 237],
        [129, 140, 248],
      ];

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resize);
      resize();

      document.addEventListener('mousemove', function(e) {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
      });

      var COUNT = Math.min(80, Math.floor(window.innerWidth / 18));
      for (var i = 0; i < COUNT; i++) {
        var c = COLORS[Math.floor(Math.random() * COLORS.length)];
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          r: Math.random() * 2 + 0.5,
          color: c,
          a: Math.random() * 0.35 + 0.1,
        });
      }

      function draw() {
        ctx.clearRect(0, 0, W, H);
        var len = particles.length;

        for (var i = 0; i < len; i++) {
          var p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < -10) p.x = W + 10;
          if (p.x > W + 10) p.x = -10;
          if (p.y < -10) p.y = H + 10;
          if (p.y > H + 10) p.y = -10;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, 6.2832);
          ctx.fillStyle = 'rgba(' + p.color[0] + ',' + p.color[1] + ',' + p.color[2] + ',' + p.a + ')';
          ctx.fill();

          for (var j = i + 1; j < len; j++) {
            var q = particles[j];
            var dx = p.x - q.x;
            var dy = p.y - q.y;
            var d2 = dx * dx + dy * dy;
            if (d2 < 22500) {
              var alpha = 0.06 * (1 - Math.sqrt(d2) / 150);
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = 'rgba(0,200,255,' + alpha + ')';
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }

          var mdx = p.x - mouse.x;
          var mdy = p.y - mouse.y;
          var md2 = mdx * mdx + mdy * mdy;
          if (md2 < 40000) {
            var malpha = 0.12 * (1 - Math.sqrt(md2) / 200);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.strokeStyle = 'rgba(0,200,255,' + malpha + ')';
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }

        requestAnimationFrame(draw);
      }

      /* Respect reduced motion */
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        draw();
      }
    })();
    </script>
  </body>
</html>
