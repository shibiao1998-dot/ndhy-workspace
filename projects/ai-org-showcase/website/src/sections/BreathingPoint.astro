---
/**
 * BreathingPoint — Emotional reset between major sections.
 * Minimal design: space, text, and restraint.
 */
---

<section class="section breathing" aria-label="情绪留白">
  <div class="section-content breathing__content">
    <div class="breathing__text anim-blur-reveal">
      <p class="breathing__line">以上不是个例</p>
      <p class="breathing__line">这是每一天的日常</p>
    </div>
  </div>
</section>

<script>
  import { observeAll } from '../utils/createObserver';
  observeAll('.breathing .anim-blur-reveal', { threshold: 0.3 });
</script>

<style>
  .breathing {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    position: relative;
    z-index: 1;
  }

  .breathing__content {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breathing__text {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .breathing__line {
    font-size: var(--fs-h2);
    font-weight: var(--fw-normal);
    color: var(--color-text-muted);
    line-height: var(--lh-heading);
    font-family: var(--font-heading);
    animation: textGlowPulse 3s ease-in-out infinite;
  }

  /* === Mobile === */
  @media (max-width: 767px) {
    .breathing {
      min-height: 50vh;
    }
  }

  /* === Desktop === */
  @media (min-width: 1024px) {
    .breathing__line {
      font-size: var(--fs-h1);
    }
  }
</style>
