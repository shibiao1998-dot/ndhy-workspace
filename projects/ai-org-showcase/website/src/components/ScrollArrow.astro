---
/**
 * ScrollArrow.astro
 * Breathing scroll-down chevron indicator.
 * Uses the `breathe` keyframe animation defined in global.css.
 */
interface Props {
  /** The ID of the target section to scroll to */
  targetId?: string;
}

const { targetId = 'section-2' } = Astro.props;
---

<a
  href={`#${targetId}`}
  class="scroll-arrow"
  aria-label="向下滚动"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    role="img"
    aria-label="向下滚动"
  >
    <polyline points="6 9 12 15 18 9" />
  </svg>
</a>

<style>
  .scroll-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
    text-decoration: none;
    animation: breathe 2s ease-in-out infinite;
    transition: color var(--dur-fast) var(--ease-out);
    border-radius: var(--radius-full);
    /* Center horizontally when placed in a flex/grid parent */
    margin-inline: auto;
  }

  .scroll-arrow:hover {
    color: var(--color-text);
  }

  .scroll-arrow:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
