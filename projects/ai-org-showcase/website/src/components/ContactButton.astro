---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'ghost';
  icon?: string;
  class?: string;
}

const { href, label, variant = 'primary', icon, class: className = '' } = Astro.props;
---

<a
  class:list={['contact-btn', `contact-btn--${variant}`, className]}
  href={href}
  role="button"
>
  {icon && <span class="contact-btn__icon" aria-hidden="true">{icon}</span>}
  <span class="contact-btn__label">{label}</span>
</a>

<style>
  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    text-decoration: none;
    cursor: pointer;
    transition: color var(--dur-micro) var(--ease-out),
                background var(--dur-micro) var(--ease-out),
                box-shadow var(--dur-micro) var(--ease-out),
                transform var(--dur-micro) var(--ease-out);
  }

  .contact-btn--primary {
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
  }

  .contact-btn--primary:hover {
    color: var(--color-text-bright);
    box-shadow: var(--shadow-glow-sm);
    transform: translateY(-1px);
  }

  .contact-btn--primary:active {
    color: var(--color-accent);
    transform: scale(0.97);
    box-shadow: none;
  }

  .contact-btn--ghost {
    color: var(--color-text-muted);
    background: transparent;
    border: none;
  }

  .contact-btn--ghost:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .contact-btn--ghost:active {
    color: var(--color-accent-active);
  }
</style>
