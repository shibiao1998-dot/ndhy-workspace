:80 {
	root * /srv
	file_server

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self'"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# HTML: short cache for quick updates
	@html {
		path *.html /
	}
	header @html Cache-Control "public, max-age=60, must-revalidate"

	# Static assets: longer cache
	@assets {
		path *.css *.js *.ico *.svg *.png *.jpg *.webp *.woff2
	}
	header @assets Cache-Control "public, max-age=86400, stale-while-revalidate=604800"

	# Gzip compression
	encode gzip

	# Handle 404
	handle_errors {
		respond "{err.status_code} {err.status_text}" {err.status_code}
	}
}
